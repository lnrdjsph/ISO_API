{
    "private": true,
    "scripts": {
        "dev": "npm run development",
        "development": "mix",
        "watch": "mix watch",
        "watch-poll": "mix watch -- --watch-options-poll=1000",
        "hot": "mix watch --hot",
        "prod": "npm run production",
        "production": "mix --production",
        "build": "vite build"
    },
    "devDependencies": {
        "axios": "^1.1.2",
        "laravel-mix": "^6.0.49",
        "laravel-vite-plugin": "^1.2.0",
        "lodash": "^4.17.19",
        "vite": "^6.3.5"
    },
    "dependencies": {
        "@tailwindcss/postcss": "^4.1.8",
        "postcss": "^8.5.4",
        "tailwindcss": "^4.1.8"
    }
}
